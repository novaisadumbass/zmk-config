if SHIELD_ERGONAUT_DONGLE

config ZMK_KEYBOARD_NAME
    default "ergonaut"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

config USB_HID_POLL_INTERVAL_MS
    default 1

config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
    default 2

endif # SHIELD_ERGONAUT_DONGLE

if SHIELD_ERGONAUT_LEFT || SHIELD_ERGONAUT_RIGHT || SHIELD_ERGONAUT_DONGLE

config ZMK_SPLIT
    default y

endif # SHIELD_ERGONAUT_LEFT || SHIELD_ERGONAUT_RIGHT || SHIELD_ERGONAUT_DONGLE
